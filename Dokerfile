# Imagen ligera
FROM node:18-alpine

# Directorio de trabajo
WORKDIR /usr/app

# Copiar archivos de dependencias
COPY package*.json ./

# Instalar dependencias
RUN npm install --omit=dev

# Copiar el resto del código
COPY . .

# Puerto de la app
EXPOSE 3000

# Comando de inicio
CMD ["node", "index.js"]
